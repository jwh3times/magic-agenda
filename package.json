{
  "name": "magic-agenda",
  "private": true,
  "version": "1.0.1",
  "description": "A tactile, multi-user task board — a draggable sticky-note calendar that syncs across devices.",
  "license": "MIT",
  "author": "Jerry Holland",
  "homepage": "https://magicagenda.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/jwh3times/magic-agenda.git"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.108.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
